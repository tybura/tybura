---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "tybura\u00AE - multidisciplinary designer, developer and storyteller." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Emil Tybura is an award-winning designer, storyteller, thinker. Over 8 years of experience in transforming brands, websites and startups."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="624012a1-ebf7-4ac3-ad93-852f63cc5402"></script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7KGSVQG4D8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7KGSVQG4D8');
    </script>
  </head>
  <body>
