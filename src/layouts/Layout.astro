---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "tybura\u00AE - multidisciplinary designer, developer and storyteller." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Emil Tybura is an award-winning designer, storyteller, thinker. Over 8 years of experience in transforming brands, websites and startups."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
