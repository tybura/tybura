---
---

<nav class="navbar">
  <div class="nav-left" id="nav-main">
    <a href="/" class="nav-link">Home</a>
    <a href="/about" class="nav-link">About</a>
    <button class="nav-link nav-btn" id="nav-contact-open">Contact</button>
  </div>

  <div class="nav-left nav-contact" id="nav-contact">
    <button class="nav-link nav-btn" id="nav-contact-close">Menu</button>
    <a href="mailto:emil@tybura.com" class="nav-link">emil@tybura.com</a>
    <a href="tel:+48884826830" class="nav-link">+48 884-826-830</a>
    <a
      href="https://instagram.com/tybura_com"
      target="_blank"
      rel="noopener"
      class="nav-link">@tybura_com</a
    >
  </div>

  <div class="nav-center">
    <span class="recently-played" id="recently-played">
      <span class="recently-played-label">Recently played:</span>
      <span class="recently-played-track" id="recently-played-track"
        >Loading...</span
      >
    </span>
  </div>

  <div class="nav-right">
    <div class="nav-socials">
      <a href="#" class="nav-link">IG</a>
      <span class="separator">/</span>
      <a href="#" class="nav-link">TT</a>
      <span class="separator">/</span>
      <a href="#" class="nav-link">LI</a>
      <span class="separator">/</span>
      <a href="#" class="nav-link">Are.na</a>
    </div>
    <div class="nav-time" id="nav-time">
      <span>10:15:16 PM</span>
    </div>
  </div>

  <div class="nav-border"></div>
</nav>

<script>
  // Clock
  function updateTime() {
    const el = document.getElementById("nav-time");
    if (!el) return;
    const span = el.querySelector("span");
    if (span) {
      span.textContent = new Date().toLocaleTimeString("en-US", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      });
    }
  }
  updateTime();
  setInterval(updateTime, 1000);

  // Last.fm
  const API_URL =
    "https://ws.audioscrobbler.com/2.0/?method=user.getrecenttracks&user=tybura&api_key=2b8dffb034a59af8058573c8e0d5b2d0&format=json&limit=1";

  let lastTrackId: string | null = null;

  async function fetchTrack() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) return;
      const data = await res.json();
      const tracks = data.recenttracks?.track;
      if (!tracks || tracks.length === 0) return;

      const track = Array.isArray(tracks) ? tracks[0] : tracks;
      const artist = track.artist?.["#text"] || track.artist || "";
      const name = track.name || "";
      const trackId = `${artist} - ${name}`;

      if (trackId === lastTrackId) return;
      lastTrackId = trackId;

      const isNowPlaying =
        track["@attr"] && track["@attr"].nowplaying === "true";

      const labelEl = document.querySelector(".recently-played-label");
      const trackEl = document.getElementById("recently-played-track");
      if (labelEl) {
        labelEl.textContent = isNowPlaying
          ? "Now playing:"
          : "Recently played:";
      }
      if (trackEl) {
        trackEl.textContent = `${name} - ${artist}`;
      }
    } catch {
      // silent fail
    }
  }

  fetchTrack();
  setInterval(fetchTrack, 5000);

  // Contact submenu toggle
  const navMain = document.getElementById("nav-main");
  const navContact = document.getElementById("nav-contact");
  const openBtn = document.getElementById("nav-contact-open");
  const closeBtn = document.getElementById("nav-contact-close");

  openBtn?.addEventListener("click", () => {
    navMain?.classList.add("is-hidden");
    navContact?.classList.add("is-visible");
  });

  closeBtn?.addEventListener("click", () => {
    navContact?.classList.remove("is-visible");
    navMain?.classList.remove("is-hidden");
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 38px;
    display: flex;
    align-items: center;
    padding: 0 var(--content-padding);
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .nav-link {
    text-align: center;
    white-space: nowrap;
  }

  /* ---- button reset ---- */
  .nav-btn {
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
    color: inherit;
    font: inherit;
    letter-spacing: inherit;
    padding: 0;
    cursor: pointer;
  }

  .nav-btn:hover {
    border-bottom-color: var(--color-text);
  }

  /* ---- contact submenu ---- */
  .nav-contact {
    display: none;
  }

  .nav-contact.is-visible {
    display: flex;
  }

  .nav-left.is-hidden {
    display: none;
  }

  /* ---- center ---- */
  .nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .recently-played {
    display: flex;
    gap: 0.3em;
    white-space: nowrap;
    text-align: center;
  }

  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .nav-socials {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .separator {
    opacity: 0.5;
  }

  .nav-time {
    width: 70px;
    text-align: right;
  }

  .nav-border {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background-color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .nav-center {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .nav-left {
      gap: 16px;
    }

    .nav-right {
      gap: 12px;
    }

    .nav-socials {
      display: none;
    }

    .nav-time {
      width: auto;
    }
  }
</style>
