---
const photos = [
  {
    src: "/images/photo-torun-40f21b.png",
    date: "September 06, 2025 / Torun, Poland",
    caption: "The night I got wasted af.",
  },
  {
    src: "/images/photo-joshua-tree-4d7d48.png",
    date: "August 23, 2025 / Joshua Tree National Park, CA",
    caption: "The day I got engaged.",
  },
];
---

<section class="photos">
  {
    photos.map((photo) => (
      <div class="photo-card">
        <div class="photo-frame">
          <img src={photo.src} alt={photo.caption} loading="lazy" />
        </div>
        <div class="photo-meta">
          <span>{photo.date}</span>
          <span>{photo.caption}</span>
        </div>
      </div>
    ))
  }
</section>

<style>
  .photos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--gap);
    padding-bottom: 0;
    width: 100%;
  }

  .photo-card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .photo-frame {
    width: 100%;
    aspect-ratio: 702 / 495;
    overflow: hidden;
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .photo-meta {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  @media (max-width: 640px) {
    .photos {
      grid-template-columns: 1fr;
    }

    .photo-card {
      grid-column: 1;
    }

    .photo-frame {
      aspect-ratio: 4 / 3;
    }
  }
</style>
